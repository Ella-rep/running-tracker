{% extends 'base/layout.html.twig' %}
{% block title %}Dashboard - Running Tracker{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/shell.css') }}?v=20260513-shell1">
<link rel="stylesheet" href="{{ asset('css/components.css') }}?v=20260513-components1">
<link rel="stylesheet" href="{{ asset('css/dashboard.css') }}?v=20260518-home10">
{% endblock %}

{% block body %}
{% include 'components/_app_header.html.twig' with { current_page: 'dashboard', username: username } %}

<main>
  <section id="dashboard" class="visible">
    <div class="section-title">Vue d'ensemble 🏃</div>
    <div class="section-sub" id="dash-date">Chargement…</div>

    <div class="kpi-grid" id="kpi-grid"></div>
    <template id="dashboard-kpi-template">
      <article class="kpi">
        <div class="kpi-label"></div>
        <div class="kpi-value"></div>
        <div class="kpi-unit"></div>
      </article>
    </template>
    <div class="chart-wrap" id="projections-wrap">
      <div class="chart-title">Temps projetés — basé sur tes 5 dernières sorties</div>
      <div id="projections-grid" class="projections-grid"></div>
      <template id="projection-card-template">
        <article class="proj-card">
          <div class="proj-label"></div>
          <div class="proj-time"></div>
          <div class="proj-pace"></div>
        </article>
      </template>
      <template id="projection-empty-template">
        <div class="empty-hint">Pas encore assez de données.</div>
      </template>
      <div id="projections-meta" class="meta-small"></div>
    </div>
    <div class="chart-wrap" id="ef-bpm-wrap">
      <div class="chart-title">Suivi BPM — Endurance Fondamentale</div>
      <div id="ef-bpm-chart-container" class="ef-bpm-chart-container"></div>
    </div>
    <div class="chart-wrap" id="training-load-wrap">
      <div class="chart-title">Charge d'entrainement</div>
      <div class="bar-chart" id="monthly-chart"></div>
      <template id="monthly-bar-template">
        <article class="bar-col">
          <div class="bar"></div>
          <div class="bar-label"></div>
        </article>
      </template>
    </div>
    <div id="coherence-section"></div>
    <template id="coherence-alert-template">
      <div class="alert">
        <div class="alert-title"></div>
        <p class="alert-body"></p>
      </div>
    </template>
  </section>
</main>

<div class="notif" id="notif"></div>
<div class="confirm-overlay" id="confirm-overlay">
  <div class="modal">
    <div class="modal-title" id="confirm-title">Confirmation</div>
    <div id="confirm-msg"></div>
    <div class="modal-actions">
      <button class="btn" onclick="confirmDelete()">Confirmer</button>
      <button class="btn btn-ghost" onclick="closeConfirm()">Annuler</button>
    </div>
  </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/app.js') }}?v=20260518-home10"></script>
{% endblock %}
