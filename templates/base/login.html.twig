{% extends 'base/layout.html.twig' %}
{% block title %}Running Tracker — Connexion{% endblock %}

{% block stylesheets %}
  <link rel="stylesheet" href="{{ asset('css/shell.css') }}?v=20260513-shell1">
  <link rel="stylesheet" href="{{ asset('css/login.css') }}?v=20260518-login4">
{% endblock %}

{% block body %}
{% include 'components/_theme_toggle.html.twig' with { extra_classes: 'login-theme-toggle' } %}
<div id="login-root">
  <div class="login-box">
    {% include 'components/logo.html.twig' %}

    <div class="login-sub" id="login-mode-label">Connexion</div>

    <div class="field" id="auth-username-field">
      <label for="auth-username">Nom d'utilisateur</label>
      <input type="text" id="auth-username" autocomplete="username" placeholder="monpseudo">
    </div>
    <div class="field" id="auth-email-field">
      <label for="auth-email">Email</label>
      <input type="email" id="auth-email" autocomplete="email" placeholder="moi@exemple.fr">
    </div>
    <div class="field" id="auth-password-field">
      <label for="auth-password">Mot de passe</label>
      <input type="password" id="auth-password" autocomplete="current-password" placeholder="••••••••">
    </div>

    <div class="login-error" id="auth-error"></div>
    <div class="login-info" id="auth-info"></div>

    <button class="btn login-submit-btn" id="auth-btn">Se connecter</button>

    <div class="login-actions">
      <button type="button" id="forgot-password-btn" class="login-toggle">Mot de passe oublié ?</button>
      <button type="button" id="back-to-login-btn" class="login-toggle" hidden>Retour à la connexion</button>
    </div>

    <div class="login-footer">
      <span id="toggle-prefix">Pas encore de compte ? </span>
      <button type="button" id="toggle-mode" class="login-toggle">Créer un compte</button>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  <script src="{{ asset('js/login.js') }}?v=20260518-login5" defer></script>
{% endblock %}
