  rotationEnabled=!rotationEnabled;
  const btn=document.getElementById('btn-rotate');
  btn.textContent=rotationEnabled?'🧭 Rotation ON':'🧭 Rotation OFF';
  btn.style.borderColor=rotationEnabled?'var(--accent)':'var(--border)';
  btn.style.color=rotationEnabled?'var(--accent)':'var(--text-muted)';
  if(!rotationEnabled) resetNorth();
}

function resetNorth(){
  currentBearing=0; displayBearing=0;
  const mapEl=document.getElementById('map');
  if(mapEl){ mapEl.style.transition='transform 0.5s ease'; mapEl.style.transform='rotate(0deg)'; }
  const mPane=mapEl?.querySelector('.leaflet-marker-pane');
  if(mPane){ mPane.style.transform=''; }
  const oPane=mapEl?.querySelector('.leaflet-overlay-pane');
  if(oPane){ oPane.style.transform=''; }
