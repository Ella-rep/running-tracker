// ── Keyboard ──────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  if(!pts.length)return;
  if(e.code==='Space'&&e.target.tagName!=='INPUT'){e.preventDefault();togglePlay();}
  if(e.code==='KeyR')resetReplay();
  function jump(i){
    idx=Math.max(0,Math.min(i,pts.length-1));
    elapsed=pts[0].time?(pts[idx].time.getTime()-pts[0].time.getTime()):(idx/(pts.length-1))*gpxMs;
    updateDisplay(idx);updateMap(idx);
  }
  if(e.code==='ArrowRight')jump(idx+Math.max(1,Math.round(pts.length*.015)));
  if(e.code==='ArrowLeft')jump(idx-Math.max(1,Math.round(pts.length*.015)));
});

// ── Resize ────────────────────────────────────────────────────
window.addEventListener('resize',()=>{if(map)map.invalidateSize();});
</script>






