  });
}

// ============================================================
// INIT
// ============================================================
loadState();
renderDashboard();
renderPlan('tempo-weeks', tempoData, 'tempoDone');
renderPlan('prep-weeks', prepData, 'prepDone');
renderPlan('semi-weeks', semiData, 'semiDone');
renderPrepaList();
renderLog();
