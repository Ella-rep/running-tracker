# Copier en .env.local et adapter
APP_ENV=prod
APP_SECRET=           # openssl rand -hex 32
DATABASE_HOST=
DATABASE_USER=
DATABASE_NAME=
DATABASE_PORT=
DATABASE_PASSWORD=
DATABASE_VERSION=
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?serverVersion=${DATABASE_VERSION}&charset=utf8"
JWT_PASSPHRASE=       # openssl rand -hex 16
JWT_TTL=604800        # 7 jours en secondes
MAPBOX_TOKEN=pk.your_mapbox_token_here
